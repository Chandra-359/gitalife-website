// ============================================================
// Gita Life NYC — Prisma Schema
//
// Database: PostgreSQL
// To apply changes:
//   npx prisma migrate dev --name <migration_name>
//   npx prisma generate
//
// To seed the database with mock data:
//   npx prisma db seed
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// A Gita Life NYC program / event that appears as a pin on the 3D map.
model Program {
  id          String   @id @default(cuid())
  title       String
  category    String   // e.g. "Kirtan & Prasadam", "Retreat", "Wisdom Session", "Youth Festival"
  description String
  latitude    Float
  longitude   Float
  date        DateTime
  imageUrl    String?  // nullable — optional program photo URL

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
